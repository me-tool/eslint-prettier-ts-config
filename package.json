{
  "name": "@me-tool/eslint-prettier-ts-config",
  "version": "2.0.8",
  "description": "Opinionated ESLint v9 flat config + Prettier for TypeScript — AI coding guardrails",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.d.mts",
      "import": "./src/index.mjs",
      "default": "./src/index.mjs"
    },
    "./cspell": {
      "types": "./src/configs/cspell.d.mts",
      "import": "./src/configs/cspell.mjs",
      "default": "./src/configs/cspell.mjs"
    },
    "./barrel": {
      "types": "./src/configs/barrel.d.mts",
      "import": "./src/configs/barrel.mjs",
      "default": "./src/configs/barrel.mjs"
    },
    "./nest-naming": {
      "types": "./src/configs/nest-naming.d.mts",
      "import": "./src/configs/nest-naming.mjs",
      "default": "./src/configs/nest-naming.mjs"
    },
    "./prettier": {
      "import": {
        "types": "./src/prettier.d.mts",
        "default": "./src/prettier.mjs"
      },
      "require": {
        "types": "./src/prettier.d.cts",
        "default": "./src/prettier.cjs"
      }
    }
  },
  "files": [
    "src/"
  ],
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  },
  "author": "halo xie",
  "license": "ISC",
  "homepage": "https://github.com/me-tool/eslint-prettier-ts-config#readme",
  "bugs": {
    "url": "https://github.com/me-tool/eslint-prettier-ts-config/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/me-tool/eslint-prettier-ts-config.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "eslint",
    "eslintconfig",
    "prettier",
    "typescript",
    "flat-config",
    "ai-coding"
  ],
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-n": "^18.0.1",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.6.0",
    "typescript-eslint": "^8.60.1"
  },
  "peerDependencies": {
    "@cspell/eslint-plugin": ">=10.0.1",
    "eslint": ">=10.4.1",
    "prettier": ">=3.8.3",
    "typescript": ">=6.0.3"
  },
  "peerDependenciesMeta": {
    "prettier": {
      "optional": true
    },
    "typescript": {
      "optional": true
    },
    "@cspell/eslint-plugin": {
      "optional": true
    }
  }
}
